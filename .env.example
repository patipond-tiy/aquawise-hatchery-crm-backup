# Copy to .env.local and fill in real values

# ----- Supabase (get from https://supabase.com/dashboard/project/_/settings/api) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Feature flags -----
# Both must be set to the same value. NEXT_PUBLIC_* variant is required so
# client bundles pick up the same setting (regular USE_MOCK is server-only).
USE_MOCK=true
NEXT_PUBLIC_USE_MOCK=true

# Mock billing state when USE_MOCK=true. Affects what the Settings → Billing tab shows.
# Values: trialing-25 | trialing-2 | trial_expired | active | past_due
MOCK_BILLING_STATE=trialing-25

# ----- Stripe (see docs/STRIPE.md for setup) -----
# Required when USE_MOCK=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ----- App -----
# Used for Stripe Checkout success/cancel URLs and the Customer Portal return URL.
# Local: http://localhost:3000  ·  Prod: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Epic K — LINE-bot batch integration (WS4) -----
# Contract: docs/aquawise-updated-docs/K-INTEGRATION-CONTRACT.md §3.
# TWO ES256 key pairs, TWO audiences (confused-deputy prevention). PEM; multi-
# line stored with literal \n escapes (un-escaped at load). Generate dev keys:
#   node -e "import('jose').then(async j=>{const k=await j.generateKeyPair('ES256');
#   console.log((await j.exportPKCS8(k.privateKey)).replace(/\n/g,'\\n'));
#   console.log((await j.exportSPKI(k.publicKey)).replace(/\n/g,'\\n'))})"
#
# Read/claim flow (bot→CRM): CRM verifies the bot's bearer with the PUBLIC key;
# the token-refresh endpoint signs with the PRIVATE key. The line-bot holds the
# matching CRM_JWT_PRIVATE_KEY counterpart (issued via /api/v1/auth/token).
CRM_JWT_PUBLIC_KEY=
CRM_JWT_PRIVATE_KEY=
# Webhook flow (CRM→bot): CRM signs outbound batch-warnings with this PRIVATE
# key (aud=line-bot-webhook). The line-bot verifies with the matching public
# key (CRM_WEBHOOK_JWT_PUBLIC_KEY — give that to the line-bot consumer).
CRM_WEBHOOK_JWT_PRIVATE_KEY=
CRM_WEBHOOK_JWT_PUBLIC_KEY=
# Client-credentials the line-bot presents at boot to /api/v1/auth/token.
LINE_BOT_CLIENT_ID=
LINE_BOT_CLIENT_SECRET=
# Base URL the K4 webhook publisher POSTs to ({base}/api/crm-events/batch-warning).
LINE_BOT_BASE_URL=https://line-bot-staging.aquawise.app
# Bearer secret for the K4 retry cron (app/api/cron/deliver-crm-events).
CRON_SECRET=
